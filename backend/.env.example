# ══════════════════════════════════════════════════════════════
# SOHOBI 통합 환경 변수 템플릿
# 이 파일을 복사하여 .env 로 저장하고 값을 채우십시오.
# ══════════════════════════════════════════════════════════════

# ── Oracle DB (상권 에이전트 — 팀 공용 서버) ───────────────────
# Connection Type: SID
ORACLE_USER=shobi
ORACLE_PASSWORD=<password>
ORACLE_HOST=10.1.92.119
ORACLE_PORT=1521
ORACLE_SID=xe

# ── Azure OpenAI (핵심 — 전 에이전트 공통) ─────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── 에이전트별 모델 오버라이드 (미설정 시 AZURE_DEPLOYMENT_NAME으로 fallback) ─
# AZURE_ADMIN_DEPLOYMENT=gpt-4o
# AZURE_FINANCE_DEPLOYMENT=gpt-4o
# AZURE_LEGAL_DEPLOYMENT=gpt-4o
# AZURE_LOCATION_DEPLOYMENT=gpt-4o
# AZURE_CHAT_DEPLOYMENT=gpt-4.1-mini
# AZURE_ROUTER_DEPLOYMENT=gpt-4.1-mini

# ── Azure OpenAI — 임베딩 ────────────────────────────────────
# CHOI 법령 RAG: text-embedding-3-small
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# NAM2 정부지원사업 RAG: text-embedding-3-large (3072차원)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMS=3072

# ── Azure AI Search ──────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KEY=<your-search-admin-key>
AZURE_SEARCH_INDEX=legal-index
AZURE_SEARCH_INDEX_NAME=gov-programs-index

# ── Azure Cosmos DB ──────────────────────────────────────────
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-key>
COSMOS_CONNECTION_STRING=AccountEndpoint=https://<your-cosmos>.documents.azure.com:443/;AccountKey=<your-cosmos-key>;
COSMOS_DATABASE_NAME=sohobidb

# ── Azure Blob Storage ──────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-storage>;AccountKey=<your-key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=sohobi-docs

# ── 정부지원사업 전용 Azure 자격증명 (NAM — GOV_* 우선 적용) ──
# gov-programs-index는 text-embedding-3-large(3072d)로 구축됨.
# 프로덕션 AZURE_* 변수(CHOI 법령 검색용)와 충돌하므로 별도 변수 사용.
GOV_OPENAI_ENDPOINT=https://sohobi-openai.openai.azure.com/
GOV_OPENAI_API_KEY=<gov-openai-api-key>
GOV_OPENAI_API_VERSION=2024-08-01-preview
GOV_EMBEDDING_DEPLOYMENT=text-embedding-3-large
GOV_SEARCH_ENDPOINT=https://sohobi-search.search.windows.net
GOV_SEARCH_API_KEY=<gov-search-admin-key>
GOV_SEARCH_INDEX_NAME=gov-programs-index

# ── 서울시 오픈 API (CHOI — 상권 분석) ───────────────────────
SEOUL_API_KEY=<your-seoul-api-key>

# ── 로그 내보내기 (GET /api/v1/logs/export) ──────────────────────
# python3 -c "import secrets; print(secrets.token_urlsafe(32))" 로 생성
# Azure Container Apps 환경변수에도 동일한 값 등록 필요
EXPORT_SECRET=<generate-with-secrets.token_urlsafe-32>

# ── 공공데이터 API 키 (NAM2 — 정부지원사업 데이터 수집) ──────
GOV24_API_KEY=<your-gov24-api-key>
KSTARTUP_API_KEY=<your-data-go-kr-key>
KISED_SPACE_API_KEY=<your-data-go-kr-key>
KISED_AGENCY_API_KEY=<your-data-go-kr-key>
KISED_EDU_API_KEY=<your-data-go-kr-key>
SME24_API_KEY=<your-sme24-api-key>
BIZINFO_API_KEY=<your-bizinfo-api-key>

# ── Azure Function App (NAM2 데이터 자동 수집) ───────────────
FUNCTION_APP_NAME=<your-function-app-name>

# ── 지도 외부 API (WOO — map_data_router) ────────────────────
# VWorld API: 용도지역(/map/land-use), WFS 행정동 경계
# 발급: https://www.vworld.kr/dev/v4dv_apicenter_s001.do
VWORLD_API_KEY=<your-vworld-api-key>
VWORLD_DOMAIN=https://sohobi.net   # 도메인 기반 인증 — VWorld 포털 등록 URL과 일치 필요

# Kakao REST API: 동 중심좌표(/map/dong-centroids)
# 발급: https://developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_REST_KEY=<your-kakao-rest-api-key>

# 한국관광공사 API: 축제 실시간 조회(/map/festivals)
# 발급: https://api.visitkorea.or.kr
KTO_GW_INFO_KEY=<your-kto-api-key>

# ── 보안: API 인증 ──────────────────────────────────────────────
# python3 -c "import secrets; print(secrets.token_urlsafe(48))" 로 생성
# 미설정 시 인증 비활성화 (로컬 개발 전용)
# API_SECRET_KEY=

# ── 보안: IP 제한 (하드 방화벽) ─────────────────────────────────
# 설정 시 해당 IP만 접근 허용. 미설정 시 비활성화.
# ALLOWED_IPS=1.2.3.4,5.6.7.8

# ── Rate Limit 면제 IP ──────────────────────────────────────────
# 기본 면제: 127.0.0.1, ::1 (로컬)
# 팀원 IP 추가 시 rate limit 완전 면제 + ALLOWED_IPS 활성 시 자동 통과
# 팀원 IP 확인: curl $BACKEND_HOST/api/v1/my-ip
# RATE_LIMIT_EXEMPT_IPS=203.0.113.10,198.51.100.20

# ── CORS 추가 origin ────────────────────────────────────────────
# Production 백엔드에서 localhost 프론트 테스트 허용
# CORS_EXTRA_ORIGINS=http://localhost:5173,http://localhost:3000
