# ================================================================
# SOHOBI Backend 환경변수
# 이 파일을 복사해서 .env로 저장 후 실제 값 입력
# .env는 절대 Git에 올리지 말 것!
# ================================================================

# ── Azure PostgreSQL ────────────────────────────────────────────
PG_HOST=sohobi-db-prod.postgres.database.azure.com
PG_PORT=5432
PG_DB=sohobi
PG_USER=공유받은_관리자_ID
PG_PASSWORD=공유받은_비밀번호
PG_SSL_MODE=require

# ── VWorld API (지도/지적도/공시지가) ───────────────────────────
# 발급처: https://www.vworld.kr/dev/v4dv_apicenter_s001.do
VWORLD_API_KEY=<your-vworld-api-key>

# ── Kakao REST API (상가 상세정보 검색) ─────────────────────────
# 발급처: https://developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_REST_KEY=<your-kakao-rest-api-key>

# ── 한국관광공사 API (랜드마크/축제 데이터) ─────────────────────
# 발급처: https://api.visitkorea.or.kr
KTO_GW_INFO_KEY=<your-kto-api-key>